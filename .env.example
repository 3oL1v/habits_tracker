# Shared
NODE_ENV=development
POSTGRES_DB=habit_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/habit_tracker?schema=public

# Backend
PORT=3001
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-to-a-long-random-string
TELEGRAM_BOT_TOKEN=replace-with-your-real-bot-token
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
ALLOW_DEV_AUTH=true
DEV_AUTH_TELEGRAM_ID=1000001
DEV_AUTH_FIRST_NAME=Demo
DEV_AUTH_USERNAME=habitdemo

# Frontend
VITE_API_BASE_URL=/api
VITE_APP_NAME=Habit Tracker Mini App
VITE_DEV_AUTH=true

# Bot
BOT_PORT=3002
WEBAPP_URL=https://your-single-service-domain.example

