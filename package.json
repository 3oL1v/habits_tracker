{
  "name": "habit-tracker-mini-app",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "concurrently -n backend,frontend,bot -c magenta,cyan,green \"pnpm --filter @habit-tracker/backend dev\" \"pnpm --filter @habit-tracker/frontend dev\" \"pnpm --filter @habit-tracker/bot dev\"",
    "build": "pnpm --filter @habit-tracker/backend prisma:generate && pnpm -r build",
    "build:backend": "pnpm --filter @habit-tracker/backend build",
    "build:frontend": "pnpm --filter @habit-tracker/frontend build",
    "build:bot": "pnpm --filter @habit-tracker/bot build",
    "start": "concurrently -k -n backend,bot -c magenta,green \"pnpm start:backend\" \"pnpm start:bot\"",
    "start:backend": "pnpm --filter @habit-tracker/backend start",
    "start:bot": "pnpm --filter @habit-tracker/bot start",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "prisma:generate": "pnpm --filter @habit-tracker/backend prisma:generate",
    "prisma:migrate": "pnpm --filter @habit-tracker/backend prisma:migrate",
    "prisma:studio": "pnpm --filter @habit-tracker/backend prisma:studio",
    "seed": "pnpm --filter @habit-tracker/backend seed",
    "setup": "node scripts/setup.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.28.0"
  }
}
